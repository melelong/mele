{
  "name": "mele",
  "version": "0.0.1",
  "description": "A front-end scaffolding tool",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "pnpm --filter=mele-cli lint",
    "format": "pnpm --filter=mele-cli format",
    "v:20": "nvm use 20",
    "v:19": "nvm use 19",
    "v:18": "nvm use 18",
    "v:17": "nvm use 17",
    "v:16": "nvm use 16",
    "v:15": "nvm use 15",
    "v:14": "nvm use 14",
    "v:13": "nvm use 13",
    "v:12": "nvm use 12",
    "stage": "lint-staged",
    "prepare": "husky install"
  },
  "author": "melelong",
  "license": "MIT",
  "devDependencies": {
    "eslint": "8.57.0",
    "husky": "^9.1.4",
    "lint-staged": "^15.2.8",
    "npm-run-all": "^4.1.5",
    "prettier": "3.3.3",
    "typescript": "5.5.4"
  },
  "lint-staged": {
    "packages/mele-cli/**/*.{js,cjs,mjs,ts,json}": [
      "pnpm --filter=mele-cli lint",
      "pnpm --filter=mele-cli format"
    ]
  }
}