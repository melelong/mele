{
  "name": "mele-cli",
  "version": "0.0.1",
  "description": "A front-end scaffolding tool",
  "bin": {
    "mele": "./bin/index.cjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/melelong/mele"
  },
  "homepage": "https://github.com/melelong/mele",
  "scripts": {
    "ts:init": "tsc --init",
    "ts:build": "tsc",
    "ts:run": "ts-node",
    "webpack:init": "webpack init",
    "build": "webpack --mode=production --node-env=production",
    "build:dev": "webpack --mode=development",
    "build:prod": "webpack --mode=production --node-env=production",
    "watch": "webpack --watch",
    "dev": "ts-node ./src/index.ts",
    "lint": "eslint . --fix",
    "format": "prettier . --write"
  },
  "keywords": [
    "mele",
    "mele-cli",
    "front-end",
    "format",
    "eslint",
    "husky",
    "prettier",
    "vue",
    "react",
    "angular"
  ],
  "author": "melelong",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.2",
    "@eslint/js": "^9.8.0",
    "@types/ejs": "^3.1.5",
    "@types/i18n": "^0.13.12",
    "@types/node": "^22.0.0",
    "@webpack-cli/generators": "^3.0.7",
    "babel-loader": "^9.1.3",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^12.0.2",
    "eslint": "9.x",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.8.0",
    "prettier": "^3.3.3",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^7.18.0",
    "webpack": "^5.93.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ejs": "^3.1.10",
    "i18n": "^0.15.1",
    "inquirer": "^10.1.6"
  }
}